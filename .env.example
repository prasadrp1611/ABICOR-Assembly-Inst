# Copy this file to ".env" and fill in your keys.
GEMINI_API_KEY=your-api-key-here
EXA_API_KEY=your-api-key-here

# Optional — HuggingFace token to enable the gated SAM 3 segmentation backend.
# Accept the license at https://huggingface.co/facebook/sam3 first.
# Without it, the app falls back to SAM 2.1 / SAM 1 automatically.
HF_TOKEN=

# Optional — override SAM backend preference (first that loads wins).
# SAM_PREFERENCE=sam3,sam2,sam1
