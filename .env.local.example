# ABICOR — LOCAL use via the team key-vault.
# Copy this file to ".env", then paste the VAULT TOKEN your team gave you.
# This routes Gemini through the team vault on a REVOCABLE token — you never hold the real key.
GEMINI_PROXY_URL=https://vault.darth-hidious.com
GEMINI_API_KEY=hsk_paste-the-token-your-team-gave-you
