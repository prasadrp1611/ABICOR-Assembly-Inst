# secrets — never commit real keys
.env

# revocable access codes (operator-managed; contains code hashes)
access_codes.json

# session document store (runtime state; rebuilt from jobs/ if deleted)
sessions.json

# key-vault runtime: handshake-token hashes, usage ledger, kill flag
keyvault/tokens.json
keyvault/usage.json
keyvault/KILL

# containerised / external data dir (ABICOR_DATA_DIR / VAULT_STATE_DIR)
data/
*/data/

# incident intake queue (user-reported problems for the support bot)
incidents/

# runtime job data (uploaded videos, frames, generated docs)
jobs/

# python
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# generated / temp office files
*.docx
~$*
.DS_Store
Thumbs.db
