# ABICOR key-vault — copy this to keyvault/.env and fill in.
# The real keyvault/.env is gitignored. NEVER commit it.

# The ONE place the real Gemini key lives (only on your Hetzner box).
# Use your SMALL-FLOAT key (e.g. a project capped at ~20 EUR), NOT the 214 EUR one.
# The vault caps below are a second belt; the small-float key is the first.
GEMINI_API_KEY=put-your-real-gemini-key-here

# Shared secret your Rocky bot sends as the  X-Admin-Token  header to
# issue / revoke / monitor tokens. Make it long and random.
VAULT_ADMIN_TOKEN=generate-a-long-random-string

# Hard ceiling across ALL tokens, in Gemini token-count. 0 = unlimited.
# e.g. 5000000 caps the whole vault at ~5M tokens no matter how many codes exist.
VAULT_GLOBAL_TOKEN_CAP=0

# Port the vault listens on.
VAULT_PORT=8800

# Bind address. Default 127.0.0.1 — keep it local and let your HTTPS reverse proxy
# (Caddy/nginx/Cloudflare) front it. Only set 0.0.0.0 if you have a firewall in place.
VAULT_HOST=127.0.0.1

# Where state (tokens.json, usage.json, KILL) is written. Defaults next to the code;
# point it at a writable dir if the install path is read-only (e.g. /opt/.../state).
# VAULT_STATE_DIR=/opt/abicor/keyvault
